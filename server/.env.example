DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gameassist
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=your_redis_password

WEBMAN_USER=
WEBMAN_GROUP=

# RonnyPay 旧启用状态：仅在 payment_active_provider 尚不存在时用于首次迁移
RONNYPAY_ORDER_ENABLED=0
RONNYPAY_MERCHANT_ID=
RONNYPAY_PRIVATE_KEY_PATH=
RONNYPAY_CALLBACK_SECRET=
RONNYPAY_NOTIFY_URL=https://your-domain.example/api/recharge/ronnypay/notify
RONNYPAY_WALLET_TYPE=1
RONNYPAY_BANK_CODE=971025
RONNYPAY_BASE_URL=https://ronnypay.com

# MkPay：敏感值只写服务器 .env，禁止提交仓库或录入后台数据库
MKPAY_BASE_URL=https://pay.mkpay8888.com
MKPAY_MERCHANT_ID=
MKPAY_MERCHANT_SECRET=
MKPAY_PRODUCT_CODE=VN01
MKPAY_NOTIFY_URL=https://your-domain.example/api/recharge/mkpay/notify
