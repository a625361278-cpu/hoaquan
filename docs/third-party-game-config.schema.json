                "minFlowerLevel"
              ],
              "properties": {
                "unlockLand": {
                  "type": "boolean",
                  "default": false
                },
                "harvestEnabled": {
                  "type": "boolean",
                  "default": false
                },
                "plantEnabled": {
                  "type": "boolean",
                  "default": false
                },
                "videoSpeedup": {
                  "type": "boolean",
                  "default": false
                },
                "useSpeedCard": {
                  "type": "boolean",
                  "default": false
                },
                "speedCardLimit": {
                  "type": "number",
                  "default": 20
                },
                "waterThreshold": {
                  "type": "number",
                  "default": 0
                },
                "taskMode": {
                  "type": "boolean",
                  "default": true
