              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "videoSpeedup": {
                  "type": "boolean",
                  "default": false
                },
                "upgrade": {
                  "type": "boolean",
                  "default": false
                },
                "targetLevel": {
                  "type": "number",
                  "default": 20
                }
              }
            },
            "water": {
              "type": "object",
