                    "customerOrder",
                    "residentOrder",
                    "artSell",
                    "flowerNews",
                    "palaceOrder",
                    "unionRace"
                  ],
                  "properties": {
                    "customerOrder": {
                      "type": "number",
                      "default": 1
                    },
                    "residentOrder": {
                      "type": "number",
                      "default": 2
                    },
                    "artSell": {
                      "type": "number",
                      "default": 6
                    },
                    "flowerNews": {
                      "type": "number",
                      "default": 3
                    },
                    "palaceOrder": {
                      "type": "number",
                      "default": 4
                    },
                    "unionRace": {
                      "type": "number",
                      "default": 3
                    }
                  }
                },
                "plantingMode": {
                  "type": "string",
                  "default": "quality"
                },
                "flowerQuality": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": [
                    "green",
                    "blue",
                    "purple",
                    "gold",
                    "red"
                  ]
                },
                "minFlowerLevel": {
                  "type": "number",
                  "default": 0
                }
              }
            },
            "friendSteal": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enabled",
                "includeElf",
                "stealMode",
                "qualities",
                "buyCount",
                "buyStealCount"
              ],
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "includeElf": {
                  "type": "boolean",
                  "default": false
                },
                "stealMode": {
                  "type": "string",
                  "default": "quality"
                },
                "qualities": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": [
                    "green",
                    "blue",
                    "purple",
                    "gold",
                    "red"
                  ]
                },
                "buyCount": {
                  "type": "boolean",
                  "default": false
                },
                "buyStealCount": {
                  "type": "number",
