                  "default": ""
                },
                "autoBuyPutCount": {
                  "type": "boolean",
                  "default": false
                },
                "buyPutCount": {
                  "type": "number",
                  "default": 0
                },
                "autoBuyFromFriend": {
                  "type": "boolean",
                  "default": false
                },
                "buyMode": {
                  "type": "string",
                  "default": "quality"
                },
                "minPutTimeDiff": {
                  "type": "number",
                  "default": 0
                }
              }
            }
          }
        },
        "order": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "resident",
            "customer",
            "palace",
            "group"
          ],
          "properties": {
            "resident": {
              "type": "object",
