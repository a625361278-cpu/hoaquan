                "applyAid",
                "recvAid",
                "helpFriend",
                "dispatch",
                "speedupDispatch",
                "recvDispatchReward",
                "recvPass",
                "recvPassTask",
                "recvFlowerPass",
                "recvFlowerPassTask"
              ],
              "properties": {
                "plant": {
                  "type": "boolean",
                  "default": false
                },
                "selectedIds": {
                  "type": "string",
                  "default": ""
                },
                "applyAid": {
                  "type": "boolean",
                  "default": false
                },
                "recvAid": {
                  "type": "boolean",
                  "default": false
                },
                "helpFriend": {
                  "type": "boolean",
                  "default": false
                },
                "dispatch": {
                  "type": "boolean",
                  "default": false
                },
                "speedupDispatch": {
                  "type": "boolean",
                  "default": false
                },
                "recvDispatchReward": {
                  "type": "boolean",
                  "default": false
                },
                "recvPass": {
                  "type": "boolean",
                  "default": false
                },
                "recvPassTask": {
                  "type": "boolean",
                  "default": false
                },
                "recvFlowerPass": {
                  "type": "boolean",
                  "default": false
                },
                "recvFlowerPassTask": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "art": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "unlockShelf",
                "autoPut",
                "sellMode",
                "specifiedArts",
                "flowerArtPerRack",
                "exp",
                "bookReward"
              ],
              "properties": {
                "unlockShelf": {
                  "type": "boolean",
                  "default": false
                },
                "autoPut": {
                  "type": "boolean",
                  "default": false
                },
                "sellMode": {
                  "type": "string",
                  "default": "specified"
                },
                "specifiedArts": {
                  "type": "string",
                  "default": ""
                },
                "flowerArtPerRack": {
                  "type": "number",
                  "default": 12
                },
                "exp": {
                  "type": "boolean",
                  "default": false
                },
                "bookReward": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "market": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "unlockShelf",
                "autoPut",
                "putMode",
                "qualities",
                "priceIndex",
                "maxSell",
                "putPassword",
                "autoBuyPutCount",
                "buyPutCount",
                "autoBuyFromFriend",
                "buyMode",
                "minPutTimeDiff"
              ],
              "properties": {
                "unlockShelf": {
                  "type": "boolean",
                  "default": false
