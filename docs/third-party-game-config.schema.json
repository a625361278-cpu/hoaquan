{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gameassist.local/schemas/third-party-game-config.schema.json",
  "title": "GameAssist Third Party Start Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "request_id",
    "account_id",
    "game_username",
    "game_password",
    "config"
  ],
  "properties": {
    "type": {
      "type": "string",
      "const": "start",
      "description": "WebSocket 包类型，启动固定为 start"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "description": "本次请求编号，第三方回 started/error 时建议原样带回"
    },
    "account_id": {
      "type": "integer",
      "minimum": 1,
      "description": "GameAssist 游戏账号 ID；同一长连接承载多个账号时用于路由"
    },
    "game_username": {
      "type": "string",
      "minLength": 1,
      "description": "用户填写的游戏账号"
    },
    "game_password": {
      "type": "string",
      "minLength": 1,
      "description": "后端解密后的游戏密码，仅用于启动通信"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basic",
        "plant",
        "order",
        "union",
        "activity"
      ],
      "properties": {
        "basic": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reputation",
            "debug",
            "reconnectInterval",
            "task",
            "mail",
            "benefit",
            "sign",
            "pearl",
            "shop",
            "randomEvent",
            "cat"
          ],
          "properties": {
            "reputation": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enabled",
                "threshold"
              ],
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "threshold": {
                  "type": "number",
                  "default": 80
                }
              }
            },
            "debug": {
              "type": "boolean",
              "default": false
            },
            "reconnectInterval": {
              "type": "number",
              "default": 5
            },
            "task": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "daily",
                "weekly",
                "main",
                "story",
                "achieve"
              ],
              "properties": {
                "daily": {
                  "type": "boolean",
                  "default": false
                },
                "weekly": {
                  "type": "boolean",
                  "default": false
                },
                "main": {
                  "type": "boolean",
                  "default": false
                },
                "story": {
                  "type": "boolean",
                  "default": false
                },
                "achieve": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "mail": {
              "type": "boolean",
              "default": false
            },
            "benefit": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "buff",
                "box",
                "shareRwd",
                "antiFraudBox"
              ],
              "properties": {
                "buff": {
                  "type": "boolean",
                  "default": false
                },
                "box": {
                  "type": "boolean",
                  "default": false
                },
                "shareRwd": {
                  "type": "boolean",
                  "default": false
                },
                "antiFraudBox": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "sign": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "daily",
                "patch"
              ],
              "properties": {
                "daily": {
                  "type": "boolean",
                  "default": false
                },
                "patch": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "pearl": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "freePearl",
                "autoHire",
                "maxHireLevel",
                "maxHireTicketUsage",
                "open",
                "protectEnabled",
                "buyHireBook",
                "maxSpendDmd"
              ],
              "properties": {
                "freePearl": {
                  "type": "boolean",
                  "default": false
                },
                "autoHire": {
                  "type": "boolean",
                  "default": false
                },
                "maxHireLevel": {
                  "type": "number",
                  "default": 0
                },
                "maxHireTicketUsage": {
                  "type": "number",
                  "default": 0
                },
                "open": {
                  "type": "boolean",
                  "default": false
                },
                "protectEnabled": {
                  "type": "boolean",
                  "default": false
                },
                "buyHireBook": {
                  "type": "boolean",
                  "default": false
                },
                "maxSpendDmd": {
                  "type": "number",
                  "default": 25
                }
              }
            },
            "shop": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "videoGift",
                "cultivateShop",
                "vipShop"
              ],
              "properties": {
                "videoGift": {
                  "type": "boolean",
                  "default": false
                },
                "cultivateShop": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "autoBuy",
                    "maxSpendGold"
                  ],
                  "properties": {
                    "autoBuy": {
                      "type": "boolean",
                      "default": false
                    },
                    "maxSpendGold": {
                      "type": "number",
                      "default": 0
                    }
                  }
                },
                "vipShop": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "autoBuy",
                    "maxSpendDmd",
                    "maxSpendFloralCoin"
                  ],
                  "properties": {
                    "autoBuy": {
                      "type": "boolean",
                      "default": false
                    },
                    "maxSpendDmd": {
                      "type": "number",
                      "default": 0
                    },
                    "maxSpendFloralCoin": {
                      "type": "number",
                      "default": 0
                    }
                  }
                }
              }
            },
            "randomEvent": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enabled"
              ],
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "cat": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enabled",
                "autoRecall",
                "autoBuyFood",
                "autoFeed",
                "autoStroke"
              ],
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "autoRecall": {
                  "type": "boolean",
                  "default": false
                },
                "autoBuyFood": {
                  "type": "boolean",
                  "default": false
                },
                "autoFeed": {
                  "type": "boolean",
                  "default": false
                },
                "autoStroke": {
                  "type": "boolean",
                  "default": false
                }
              }
            }
          }
        },
        "plant": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cultivate",
            "water",
            "flower",
            "friendSteal",
            "elves",
